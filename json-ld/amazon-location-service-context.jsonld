{
  "@context": {
    "@version": 1.1,
    "locationservice": "https://locationservice.amazonaws.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "MapResource": "locationservice:MapResource",
    "Tracker": "locationservice:Tracker",
    "id": {
      "@id": "schema:identifier",
      "@type": "xsd:string"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "locationservice:status",
      "@type": "xsd:string"
    },
    "arn": {
      "@id": "locationservice:arn",
      "@type": "xsd:string"
    },
    "createdAt": {
      "@id": "schema:dateCreated",
      "@type": "xsd:dateTime"
    },
    "updatedAt": {
      "@id": "schema:dateModified",
      "@type": "xsd:dateTime"
    }
  }
}